{
  "firestore": {
    "database": "(default)",
    "location": "us-central1",
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log"
      ]
    }
  ],
  "hosting": {
    "public": "dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "headers": [
      {
        "source": "/index.html",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache, no-store, must-revalidate"
          }
        ]
      },
      {
        "source": "**/*.@(jpg|jpeg|gif|png|svg|webp|js|css|mp3|wav|woff2|ico)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=31536000, immutable"
          }
        ]
      }
    ],
    "rewrites": [
      {
        "source": "/api/witness",
        "function": {
          "functionId": "witnessPresence",
          "region": "us-central1"
        }
      },
      {
        "source": "/api/grounding",
        "function": {
          "functionId": "getGrounding",
          "region": "us-central1"
        }
      },
      {
        "source": "/api/voice",
        "function": {
          "functionId": "textToSpeech",
          "region": "us-central1"
        }
      },
      {
        "source": "/api/daily-meditation",
        "function": {
          "functionId": "getDailyMeditation",
          "region": "us-central1"
        }
      },
      {
        "source": "/api/emotion",
        "function": {
          "functionId": "analyzeEmotion",
          "region": "us-central1"
        }
      },
      {
        "source": "/api/razorpay-order",
        "function": {
          "functionId": "createRazorpayOrder",
          "region": "us-central1"
        }
      },
      {
        "source": "/api/razorpay-verify",
        "function": {
          "functionId": "verifyRazorpayPayment",
          "region": "us-central1"
        }
      },
      {
        "source": "/api/razorpay-webhook",
        "function": {
          "functionId": "razorpayWebhook",
          "region": "us-central1"
        }
      },
      {
        "source": "/api/unsubscribe",
        "function": {
          "functionId": "unsubscribe",
          "region": "us-central1"
        }
      },
      {
        "source": "/api/razorpay-subscription",
        "function": {
          "functionId": "createRazorpaySubscription",
          "region": "us-central1"
        }
      },
      {
        "source": "/api/razorpay-subscription-verify",
        "function": {
          "functionId": "verifyRazorpaySubscription",
          "region": "us-central1"
        }
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}