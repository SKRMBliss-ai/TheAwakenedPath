rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAdmin() {
      // SECURITY: require email_verified=true — Firebase Auth lets anyone sign up
      // with email/password using ANY email address; only verified emails should
      // be trusted. Without this, an attacker could register as an admin email
      // (unverified) and gain full admin access.
      return request.auth != null
        && request.auth.token.email_verified == true
        && (
          request.auth.token.email == 'shrutikhungar@gmail.com' ||
          request.auth.token.email == 'simkatyal1@gmail.com' ||
          request.auth.token.email == 'smriti.duggal@gmail.com' ||
          request.auth.token.email == 'rashmi.purbey@gmail.com' ||
          request.auth.token.email == 'skrmblissai@gmail.com'
        );
    }

    match /users/{userId}/{allPaths=**} {
      allow read: if (request.auth != null && request.auth.uid == userId) || isAdmin();
      allow write: if (request.auth != null && request.auth.uid == userId) || isAdmin();
      allow delete: if isAdmin();
    }
    
    match /activity_logs/{logId} {
      allow create: if request.auth != null;
      allow read: if isAdmin();
      allow delete: if isAdmin();
    }
    
    match /email_blasts/{blastId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }
    
    match /email_opens/{openId} {
      // The tracking pixel is fired anonymously by email clients, so we can't gate
      // creation behind auth — but we DO restrict shape to prevent garbage spam:
      //  - exactly the expected fields
      //  - reasonable size limits
      //  - no other writes (only create) and no read except admin
      allow create: if request.resource.data.keys().hasOnly(['blastId', 'userEmail', 'timestamp'])
        && request.resource.data.blastId is string
        && request.resource.data.blastId.size() < 200
        && request.resource.data.userEmail is string
        && request.resource.data.userEmail.size() < 200;
      allow read: if isAdmin();
    }
    
    match /email_clicks/{id} {
      allow read: if isAdmin();
    }
    
    match /email_unsubscribes/{id} {
      allow read: if isAdmin();
    }

    match /leads/{leadId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
      allow delete: if isAdmin();
    }

    match /lead_scans/{scanId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    match /waitlist/{entryId} {
      // Anonymous email captures from the marketing landing page (/aboutjournal).
      // Strict shape validation prevents abuse and unbounded writes.
      allow create: if request.resource.data.keys().hasOnly(['email', 'source', 'userAgent', 'createdAt'])
        && request.resource.data.email is string
        && request.resource.data.email.size() > 3
        && request.resource.data.email.size() < 200
        && request.resource.data.email.matches('^[^@\\s]+@[^@\\s]+\\.[^@\\s]+$')
        && request.resource.data.source is string
        && request.resource.data.source.size() < 60;
      allow read: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── DAILY MEDITATION ROOM ─────────────────────────────────────────────────

    match /meditation_sessions/{sessionId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null;

      match /participants/{uid} {
        allow read: if request.auth != null;
        allow write: if request.auth != null
          && (request.auth.uid == uid || isAdmin());
      }

      match /signals/{sigId} {
        allow read: if request.auth != null
          && (resource.data.to == request.auth.uid
            || resource.data.from == request.auth.uid);
        allow create: if request.auth != null
          && request.resource.data.from == request.auth.uid;
        allow update: if request.auth != null
          && resource.data.to == request.auth.uid;
      }

      match /chat/{msgId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null
          && request.resource.data.uid == request.auth.uid
          && request.resource.data.text.size() <= 100;
        allow delete: if isAdmin();
      }
    }

    match /meditation_attendance/{id} {
      allow read: if request.auth != null
        && (resource.data.uid == request.auth.uid || isAdmin());
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid;
      allow update: if request.auth != null
        && resource.data.uid == request.auth.uid;
    }

    match /meditation_journals/{id} {
      allow read: if request.auth != null
        && (resource.data.uid == request.auth.uid || isAdmin());
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid;
      allow update: if request.auth != null
        && resource.data.uid == request.auth.uid;
    }

    match /meditation_streaks/{uid} {
      allow read: if request.auth != null
        && (request.auth.uid == uid || isAdmin());
      allow write: if request.auth != null
        && (request.auth.uid == uid || isAdmin());
    }
  }
}