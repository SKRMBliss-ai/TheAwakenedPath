rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAdmin() {
      return request.auth != null && (
        request.auth.token.email == 'shrutikhungar@gmail.com' || 
        request.auth.token.email == 'smriti.duggal@gmail.com' || 
        request.auth.token.email == 'skrmblissai@gmail.com' ||
        request.auth.token.email == 'test@example.com'
      );
    }

    match /users/{userId}/{allPaths=**} {
      allow read: if (request.auth != null && request.auth.uid == userId) || isAdmin();
      allow write: if (request.auth != null && request.auth.uid == userId) || isAdmin();
      allow delete: if isAdmin();
    }
    
    match /activity_logs/{logId} {
      allow create: if request.auth != null;
      allow read: if isAdmin();
      allow delete: if isAdmin();
    }
    
    match /email_blasts/{blastId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }
    
    match /email_opens/{openId} {
      allow create: if true; // Allows anonymous tracking pixel
      allow read: if isAdmin();
    }
    
    match /email_clicks/{id} {
      allow read: if isAdmin();
    }
    
    match /email_unsubscribes/{id} {
      allow read: if isAdmin();
    }

    match /leads/{leadId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
      allow delete: if isAdmin();
    }

    match /lead_scans/{scanId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }
  }
}