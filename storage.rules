rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // 1. Previews & Assets: Publicly readable (thumbnails and UI assets)
    match /previews/{allPaths=**} {
      allow read: if true;
    }
    match /{anyFolder}/Images/{allPaths=**} {
      allow read: if true;
    }
    
    // 2. High-Quality Sacred Sounds: Private
    // These require a temporary Signed URL generated by getSecureTrackUrl
    match /Soundscapes/{allPaths=**} {
      allow read: if false;
    }
    match /mp3/Music/{allPaths=**} {
      allow read: if false;
    }

    // 3. DEBUG: Allow public read of EVERYTHING
    match /{allPaths=**} {
      allow read: if true;
    }

    // 4. Safeguard: Deny write access to non-admins
    match /{allPaths=**} {
      allow write: if request.auth != null && request.auth.token.admin == true;
    }
  }
}
